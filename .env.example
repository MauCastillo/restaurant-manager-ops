# ==============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO (.env.example)
# Copia este archivo como .env y configura tus credenciales reales o
# agrégalas en Render -> Environment -> Environment Variables / Secrets.
# ==============================================================================

# Configuración del Entorno Flask
FLASK_ENV=production
PORT=10000

# Clave secreta para sesiones de Flask
SECRET_KEY=cambiar-por-una-clave-secreta-larga-y-segura

# Ruta de Base de Datos SQLite (en Render con Disco Persistente usar ej: /var/data/app.db)
DATABASE_PATH=instance/app.db

# Credenciales de Administrador inicial (seed_data.py)
ADMIN_USER=admin
ADMIN_EMAIL=admin@manager.ops
ADMIN_PASSWORD=admin_password_aqui

# Credenciales de Correo Gmail SMTP (App Password)
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google Gemini API (OCR Manuscrito)
GEMINI_API_KEY=tu_api_key_de_gemini
GEMINI_MODEL=gemini-flash-lite-latest
